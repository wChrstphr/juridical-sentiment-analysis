








<html>
	<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

		<script src="/pastadigital/js/jquery/jquery.min.js"></script>
		<script type="text/javascript">
		(function($) {
			$(function() {
				var divOutroFormato = parent.document.getElementById('divOutroFormato');
				if(divOutroFormato){
					var $link = $(divOutroFormato).children("a");
					var $liMsgOriginal = $('#spwTabelaMensagem table.tabelaMensagem:first-child li');
					var htmlDocOriginal = dict['pastadigital.erro.desconhecido.nao.foi.possivel.apresentar.documento'] + ' ';
					htmlDocOriginal += '<a href="#" id="novoLinkDocOriginal" style="color:#CB7F08;">'+ dict["pastadigital.msg.clique.aqui"] +'</a> ' + dict["pastadigital.msg.download.arquivo"] + '';
					$liMsgOriginal.html(htmlDocOriginal);
					$('#novoLinkDocOriginal').click(
						function(){
							$link.click();
						}
					);
				}
			});

		})(jQuery);


		</script>
	</head>
	<body>
		<!-- BEGIN MESSAGE -->
<div id="spwTabelaMensagem">
<table width="100%" height="30" class="tabelaMensagem" border="0" cellpadding="0" cellspacing="0">
  <tr>
   	<td width="35" valign="top" class="alert"><img src="/pastadigital/imagens/spw/icoAlert.gif" ></td>
   	<td class="tituloMensagem"><b>
	Atenção</b></td>  </tr>
  <tr>
       <td class="alert">&nbsp;</td>
       <td tabindex="0" role="alert" id="mensagemRetorno">
           <li>Sua sessão expirou. Para acessar a pasta digital, por favor efetue novamente a consulta deste processo.</li>
       </td>
  </tr>
</table>
<table width="100%" border="0" class="tabelaMensagem" cellpadding="0" cellspacing="0">
  <tr>
       <td width="35">&nbsp;</td>
       <td>&nbsp;
       </td>
  </tr>
</table>
</div>
<!-- END MESSAGE -->

<!-- CAUSA:  -->
	</body>
</html>
